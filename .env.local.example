# Copy this file to .env.local and fill in your own Firebase project's values.
# Leave every variable unset (or delete this file) to run in local-demo mode —
# see README.md. Never commit .env.local or real credentials.

# --- Firebase Client SDK (exposed to the browser) ---
# Firebase Console -> Project settings -> General -> Your apps -> SDK setup and configuration
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
# Optional — only needed if you use Firebase Analytics (Project settings -> General)
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# --- Firebase Admin SDK (server-only, never exposed to the browser) ---
# Firebase Console -> Project settings -> Service accounts -> Generate new private key
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Keep the surrounding quotes and \n escape sequences exactly as they appear in the
# downloaded service account JSON's "private_key" field.
FIREBASE_PRIVATE_KEY=
